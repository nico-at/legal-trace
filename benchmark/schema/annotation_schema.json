{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Austrian Legal Source Retrieval Benchmark",
  "description": "Annotation schema for evaluating LLM legal source identification in Austrian law. Reference date: 2026-01-01.",
  "version": "0.5.0",

  "definitions": {
    "legal_domain": {
      "type": "string",
      "enum": [
        "civil_law",
        "criminal_law",
        "public_law",
        "labor_law",
        "tax_law"
      ]
    },

    "difficulty": {
      "type": "string",
      "enum": ["simple", "moderate", "complex"]
    },

    "contamination_tag": {
      "type": "string",
      "enum": [
        "cross_jurisdictional",
        "temporal",
        "cross_jurisdictional_temporal",
        "none"
      ]
    },

    "statute_source": {
      "type": "object",
      "required": ["law_abbreviation", "section", "law_number"],
      "properties": {
        "law_abbreviation": { "type": "string" },
        "section": { "type": "string" },
        "law_number": { "type": "string" },
        "ris_document_id": { "type": "string" },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },

    "case_law_source": {
      "type": "object",
      "required": ["court", "case_number", "legal_principle_number"],
      "properties": {
        "court": {
          "type": "string",
          "enum": ["OGH", "VfGH", "VwGH"]
        },
        "case_number": { "type": "string" },
        "legal_principle_number": { "type": "string" },
        "decision_date": {
          "type": "string",
          "format": "date"
        },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },

    "benchmark_entry": {
      "type": "object",
      "required": [
        "id",
        "question",
        "legal_domain",
        "difficulty",
        "contamination_tag",
        "statutes",
        "case_law"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "question": { "type": "string" },
        "legal_domain": { "$ref": "#/definitions/legal_domain" },
        "difficulty": { "$ref": "#/definitions/difficulty" },
        "contamination_tag": { "$ref": "#/definitions/contamination_tag" },

        "statutes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/statute_source" }
        },

        "case_law": {
          "type": "array",
          "items": { "$ref": "#/definitions/case_law_source" }
        },

        "annotator": { "type": "string" },
        "annotation_date": {
          "type": "string",
          "format": "date"
        },
        "schema_version": {
          "type": "string",
          "const": "0.5.0"
        }
      },
      "additionalProperties": false
    }
  },

  "$ref": "#/definitions/benchmark_entry"
}
